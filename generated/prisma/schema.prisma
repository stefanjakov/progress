// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum OpportunityStatus {
  WISHLIST
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  ACCEPTED
  WITHDRAWN
}

enum StageStatus {
  PENDING
  SCHEDULED
  PASSED
  FAILED
  CANCELLED
}

enum GoalHorizon {
  SHORT_TERM
  LONG_TERM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  DONE
  ARCHIVED
}

enum GoodieType {
  BOOLEAN
  COUNT
  NUMBER
}

// ----------------------------------------------------------------------------
// Interviews
// ----------------------------------------------------------------------------

model Opportunity {
  id        String            @id @default(cuid())
  company   String
  role      String
  link      String?
  priority  Int               @default(0)
  status    OpportunityStatus @default(WISHLIST)
  notes     String?
  order     Int               @default(0)
  stages    Stage[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([priority])
}

/// User-extensible catalog of stage kinds (Recruiter Screen, OA, System Design, ...).
model StageType {
  id        String   @id @default(cuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  order     Int      @default(0)
  stages    Stage[]
  createdAt DateTime @default(now())
}

model Stage {
  id            String      @id @default(cuid())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String
  stageType     StageType   @relation(fields: [stageTypeId], references: [id], onDelete: Restrict)
  stageTypeId   String
  status        StageStatus @default(PENDING)
  scheduledAt   DateTime?
  notes         String?
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([opportunityId])
  @@index([stageTypeId])
  @@index([scheduledAt])
}

// ----------------------------------------------------------------------------
// Goals / Projects / Tasks
// ----------------------------------------------------------------------------

model Goal {
  id          String      @id @default(cuid())
  title       String
  description String?
  horizon     GoalHorizon @default(SHORT_TERM)
  targetDate  DateTime?
  status      GoalStatus  @default(ACTIVE)
  completedAt DateTime?
  order       Int         @default(0)
  tasks       Task[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([targetDate])
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  order       Int           @default(0)
  tasks       Task[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

/// Belongs to EXACTLY ONE of goal | project (XOR enforced in the tRPC layer).
model Task {
  id          String    @id @default(cuid())
  title       String
  notes       String?
  done        Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int       @default(0)
  goal        Goal?     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  goalId      String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([goalId])
  @@index([projectId])
  @@index([done, dueDate])
}

/// Standalone daily list, independent of goals/projects.
model DailyTodo {
  id          String    @id @default(cuid())
  title       String
  done        Boolean   @default(false)
  date        DateTime  @default(now()) @db.Date
  order       Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([date])
}

// ----------------------------------------------------------------------------
// Goodies (daily habit tracking)
// ----------------------------------------------------------------------------

model GoodieCategory {
  id        String      @id @default(cuid())
  name      String
  type      GoodieType  @default(BOOLEAN)
  target    Float?
  unit      String?
  color     String?
  icon      String?
  active    Boolean     @default(true)
  order     Int         @default(0)
  logs      GoodieLog[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([active])
}

model GoodieLog {
  id         String         @id @default(cuid())
  category   GoodieCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String
  date       DateTime       @db.Date
  value      Float          @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([categoryId, date])
  @@index([date])
}

// ----------------------------------------------------------------------------
// App-usage streak (proxy for "days I log into progress")
// ----------------------------------------------------------------------------

/// One row per day the app is opened — the (single) user's presence streak.
model DayActivity {
  id    String   @id @default(cuid())
  date  DateTime @unique @db.Date
  count Int      @default(1)
}

// ----------------------------------------------------------------------------
// Notes
// ----------------------------------------------------------------------------

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("") // markdown
  tags      String[] // Postgres text[]
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned])
  @@index([updatedAt])
}
